.DS_Store
__pycache__/
*.pyc
*.swp

# Python packaging build artifacts (chemkit-mcp)
/build/
/dist/
*.egg-info/
*.egg

# Per-session state written by the chemkit method-gate PreToolUse hook
# (acknowledgement markers keyed by session id). Runtime state, never committed.
/.claude/.chemkit-gate/

# ---------------------------------------------------------------------------
# Runtime calculation artifacts dropped into the caller's cwd by a skill run.
# These are scratch outputs (live logs + result files) and must not be
# committed. Anchored to the repo ROOT (leading "/") and to mcp_server/ so they
# never affect the committed example artifacts under skills/**/examples/.
# (Patterns must be on their own lines — git does NOT strip trailing comments.)
# ---------------------------------------------------------------------------
/*.out
/*.json
/*.xyz
/*.cube
/*.molden
/*.png
/mcp_server/*.out
/mcp_server/*.json
/mcp_server/*.xyz
/mcp_server/*.cube
/mcp_server/*.molden
/mcp_server/*.png

# Local secrets for the fidelity driver (argo username / endpoint key).
# Never commit; an .env.example is committed instead as a template.
benchmarks/fidelity/.env.local

# Fidelity run artifacts (transcripts, .out logs, scored results). Scratch by
# default; promote chosen runs into the Zenodo/GitHub-release bundle for the paper.
benchmarks/runs/

# Local scratch from fidelity development: the driver's error dumps (large,
# transient crash JSONs) and a personal progress-tracking note. Local only.
benchmarks/error_dumps/
benchmarks/fidelity/tested.txt

# ---------------------------------------------------------------------------
# Fidelity BENCHMARK run scratch (regenerated per run; ~1 GB, not source).
# These are the volatile outputs of re-running the fidelity suite — per-model
# agent transcripts, timestamped engine-run dirs and their live .out logs, and
# ad-hoc scratch dropped at the benchmarks/ root. Curated reference data lives in
# each example's engine-reference/ + *.spec.json (kept tracked below); everything
# here is reproducible output that should never be committed.
# ---------------------------------------------------------------------------
# Per-model agent run directories (argo_<model>/ under any validation example).
benchmarks/fidelity/**/argo_*/
# Pre-fix archives and other dated run snapshots.
benchmarks/fidelity/**/_pre_fix_archive*/
# Timestamped engine-run dirs (YYYYMMDD-HHMMSS_<name>/) and their sibling .out.
benchmarks/fidelity/**/[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]-[0-9][0-9][0-9][0-9][0-9][0-9]_*/
benchmarks/fidelity/**/[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]-[0-9][0-9][0-9][0-9][0-9][0-9]_*.out
# Per-suite rollup CSVs regenerated each run.
benchmarks/fidelity/**/summary.csv
# Ad-hoc scratch dropped directly at the benchmarks/ root by manual skill runs
# (result JSON, live .out logs, geometries, cubes/moldens, plots).
benchmarks/*.out
benchmarks/*.json
benchmarks/*.xyz
benchmarks/*.err
benchmarks/*.cube
benchmarks/*.molden
benchmarks/*.png

# Safety net: keep committed example deliverables tracked.
!skills/**/examples/**

# ...but never track macOS cruft, even under examples/ (the un-ignore above
# would otherwise re-include it).
.DS_Store
**/.DS_Store
