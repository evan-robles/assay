# Template for benchmarks/fidelity/.env.local (which is gitignored).
# Copy this to .env.local and fill in your argo username:
#     cp benchmarks/fidelity/.env.example benchmarks/fidelity/.env.local
#
# CHEMKIT_LLM_API_KEY is your Argonne username (argo-proxy uses it as the key).
CHEMKIT_LLM_API_KEY=your-argo-username
CHEMKIT_LLM_MODEL=argo:o3
# argo-proxy endpoint. NOTE: 0.0.0.0 (== loopback) only works when the driver
# runs on the SAME host as the proxy. For a multi-node run (shards on other
# nodes), point this at the proxy host's real, routable hostname, e.g.
#     CHEMKIT_LLM_BASE_URL=http://<proxy-host>:60639/v1
# Argo (apps.inside.anl.gov) is only reachable from an ANL-VPN host, so the
# proxy must run somewhere on the VPN; a non-VPN node reaches it via a tunnel.
CHEMKIT_LLM_BASE_URL=http://0.0.0.0:60639/v1
