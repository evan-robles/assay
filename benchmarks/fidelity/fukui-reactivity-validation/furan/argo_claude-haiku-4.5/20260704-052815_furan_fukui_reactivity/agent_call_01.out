    _add_stdout_option(p_pka)
    _add_gate_option(p_pka)

    p_build = sub.add_parser(
        "build",
        help="Build a 3D xyz from a SMILES string OR a molecule name (Open Babel "
             "--gen3d; names are resolved online via PubChem/OPSIN/NIST).",
